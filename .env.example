# Copy this file to .env and fill in your values
# The .env file must be saved as UTF-8 (not UTF-16)

# Required: Gemini API key from https://aistudio.google.com/apikey
GEMINI_API_KEY=AIzaSy...

# Firebase client config (VITE_ prefix exposes them to the browser)
# Get these from Firebase Console → Project Settings → Your apps → Web app
VITE_FIREBASE_API_KEY=AIzaSy...
VITE_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your-project-id
VITE_FIREBASE_STORAGE_BUCKET=your-project.firebasestorage.app
VITE_FIREBASE_MESSAGING_SENDER_ID=123456789
VITE_FIREBASE_APP_ID=1:123456789:web:abcdef

# Firebase Admin (server-side token verification)
# Get from Firebase Console → Project Settings → Service accounts → Generate new private key
# Paste the entire JSON on a single line (replace newlines with \n inside the value)
FIREBASE_SERVICE_ACCOUNT={"type":"service_account","project_id":"..."}
